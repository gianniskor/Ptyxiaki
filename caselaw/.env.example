NEXT_PUBLIC_SUPABASE_URL=https://your-project-ref.supabase.co
NEXT_PUBLIC_SUPABASE_PUBLISHABLE_KEY=your-publishable-key
# Google One Tap (one-click sign-in). Web application OAuth client ID from
# Google Cloud Console. Must also be configured in the Supabase dashboard
# under Authentication → Providers → Google.
NEXT_PUBLIC_GOOGLE_CLIENT_ID=your-google-web-client-id.apps.googleusercontent.com
