# =============================================================================
# Frontend (Next.js) — local development WITHOUT Docker
# =============================================================================
# Only needed if you run the frontend directly with `npm run dev` from the
# caselaw/ folder. If you use docker-compose, configure the root ".env" instead.
#
#   cp .env.local.example .env.local
#
# This file is git-ignored — never commit real keys.
# =============================================================================

# Public URL of the backend API (see backend running on port 8000).
NEXT_PUBLIC_API_URL=http://localhost:8000

# Supabase — from Project Settings -> API.
NEXT_PUBLIC_SUPABASE_URL=https://your-project-ref.supabase.co
NEXT_PUBLIC_SUPABASE_PUBLISHABLE_KEY=sb_publishable_xxxxxxxxxxxxxxxxxxxxx

# SECRET — server-side only. Never expose to the browser. For local development, you can copy this from the root ".env" file.
SUPABASE_SERVICE_ROLE_KEY=your-service-role-key
