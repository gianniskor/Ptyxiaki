# =============================================================================
# CaseLaw — Environment configuration
# =============================================================================
# Copy this file to ".env" (same directory as docker-compose.yml) and fill in
# the values below. docker-compose loads ".env" automatically.
#
#   cp .env.example .env
#
# NEVER commit your real ".env" file — it is git-ignored on purpose.
# =============================================================================


# -----------------------------------------------------------------------------
# 1) Backend API — the ONLY value you usually need to change for deployment
# -----------------------------------------------------------------------------
# Public URL where the FastAPI backend is reachable FROM THE BROWSER.
#   • Local development (default):  http://localhost:8000
#   • Production: the public URL of your backend, e.g. https://api.your-domain.com
NEXT_PUBLIC_API_URL=http://localhost:8000


# -----------------------------------------------------------------------------
# 2) Supabase (authentication & database)
# -----------------------------------------------------------------------------
# Create a free project at https://supabase.com and copy these from
# Project Settings -> API.

# Project URL (safe to expose to the browser).
NEXT_PUBLIC_SUPABASE_URL=https://your-project-ref.supabase.co

# Publishable / anon key (safe to expose to the browser).
NEXT_PUBLIC_SUPABASE_PUBLISHABLE_KEY=sb_publishable_xxxxxxxxxxxxxxxxxxxxx

# SERVICE ROLE key — SECRET. Server-side only, full admin access to your
# database. NEVER expose it to the browser and NEVER commit it.
# For local development, you can have this in your root ".env" file, or use a Docker secret in production.
# Found in Supabase: Project Settings -> API -> service_role (Reveal).
SUPABASE_SERVICE_ROLE_KEY=your-service-role-key


# -----------------------------------------------------------------------------
# 3) LLM (LM Studio) — used by the chatbot / fact-check feature
# -----------------------------------------------------------------------------
# Run an OpenAI-compatible server (e.g. LM Studio) and expose it here.
# From inside Docker, host.docker.internal points to your host machine.
LM_STUDIO_URL=http://host.docker.internal:1234/v1
LM_STUDIO_MODEL=google/gemma-4-12b-qat
